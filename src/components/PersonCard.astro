---
import { url } from '../lib/site';
import type { Person } from '../lib/people';

interface Props {
  person: Person;
}
const { person } = Astro.props;

// Initials for the fallback avatar when no photo is provided.
const initials = person.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? '')
  .join('');
---
<article class="person">
  {person.photo
    ? <img class="person-avatar" src={url(person.photo)} alt={person.name} loading="lazy" />
    : <span class="person-avatar person-avatar--initials" aria-hidden="true">{initials}</span>}

  <div class="person-body">
    <h3>{person.name}</h3>
    {person.role && <p class="person-role">{person.role}</p>}
    {person.affiliation && <p class="person-affil">{person.affiliation}</p>}
    {person.bio && <p class="person-bio">{person.bio}</p>}
    {person.links && person.links.length > 0 && (
      <p class="person-links">
        {person.links.map((l) => (
          <a href={l.href} rel="noopener" target="_blank">{l.label}</a>
        ))}
      </p>
    )}
  </div>
</article>
