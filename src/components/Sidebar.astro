---
import { NAV, SITE, url, currentKey } from '../lib/site';

const key = currentKey(Astro.url.pathname);
const base = import.meta.env.BASE_URL;
---
<aside class="sidebar" id="sidebar">
  <a class="brand" href={url('')}>
    <img class="brand-logo" src={`${base}logos/ahli-horizontal-white.svg`} alt="AHLI — Association for Health Learning and Inference" width="220" height="69" />
    <span class="brand-sub">Health AI Summer Camp {SITE.year}</span>
  </a>

  <nav class="side-nav" aria-label="Primary">
    {NAV.map((item) => (
      <a
        href={url(item.path)}
        aria-current={key === item.path ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>

  <div class="side-section">
    <h2>Get in touch</h2>
    <div class="side-contact">
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href={url('resources')}>Camp resources</a>
      <a href={url('faq')}>Frequently asked questions</a>
    </div>
  </div>

  <div class="side-foot">
    <p>
      <strong>{SITE.dates}</strong><br />
      Co-located with {SITE.colocatedWith}.
    </p>
    <p class="side-supported">Supported by the {SITE.funder}.</p>
    <a class="side-sponsor" href={url('sponsors')} aria-label={SITE.funder}>
      <img src={`${base}logos/moore-foundation-white.svg`} alt={`${SITE.funder} logo`} width="180" height="70" />
    </a>
  </div>
</aside>
