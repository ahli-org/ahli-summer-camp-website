---
import { url } from '../lib/site';
import type { Student } from '../lib/students';

interface Props {
  student: Student;
}
const { student } = Astro.props;
const base = import.meta.env.BASE_URL;

const initials = student.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? '')
  .join('');
---
<a class="student-card" href={url(`students/${student.slug}`)}>
  {student.photo
    ? <img class="student-photo" src={`${base}${student.photo}`} alt={student.name} loading="lazy" width="700" height="700" />
    : <span class="student-photo student-photo--initials" aria-hidden="true">{initials}</span>}
  <div class="student-card-body">
    <h3>{student.name}</h3>
    {student.position && <p class="student-pos">{student.position}</p>}
    {student.affiliation && <p class="student-affil">{student.affiliation}</p>}
    <span class="student-more">View profile →</span>
  </div>
</a>
