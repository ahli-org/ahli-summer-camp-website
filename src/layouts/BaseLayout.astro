---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { SITE, url } from '../lib/site';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = `${SITE.name} ${SITE.year} — a week-long intensive in machine learning for health for PhD students. ${SITE.dates}.`,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const fullTitle = `${title} · ${SITE.shortName} ${SITE.year}`;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#161b38" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <!-- Mobile-only top bar -->
    <div class="mobile-bar">
      <a href={url('')} style="text-decoration:none">
        <span class="brand-mark">AHLI<span class="dot" style="color:var(--teal-bright)">.</span></span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-controls="sidebar" aria-expanded="false">
        Menu
      </button>
    </div>
    <div class="scrim" id="scrim" hidden></div>

    <Sidebar />

    <main id="main" class="content">
      <slot />

      <footer class="site-footer">
        <div class="wrap">
          <p>
            <strong>{SITE.name} {SITE.year}</strong><br />
            {SITE.dates} · Co-located with CHIL
          </p>
          <p>
            Supported by the {SITE.funder}.<br />
            © {year} {SITE.name}. Built with <a href="https://astro.build">Astro</a>.
          </p>
        </div>
      </footer>
    </main>

    <script>
      // Off-canvas navigation drawer for small screens.
      const body = document.body;
      const toggle = document.getElementById('navToggle');
      const scrim = document.getElementById('scrim');

      function setOpen(open: boolean) {
        body.classList.toggle('nav-open', open);
        toggle?.setAttribute('aria-expanded', String(open));
        if (scrim) scrim.hidden = !open;
      }

      toggle?.addEventListener('click', () =>
        setOpen(!body.classList.contains('nav-open'))
      );
      scrim?.addEventListener('click', () => setOpen(false));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setOpen(false);
      });
      // Close the drawer after following a link within it.
      document
        .querySelectorAll('#sidebar a')
        .forEach((a) => a.addEventListener('click', () => setOpen(false)));
    </script>
  </body>
</html>
