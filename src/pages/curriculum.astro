---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../lib/site';
import { days, dailyRhythm, readings } from '../lib/curriculum';
import type { Person } from '../lib/curriculum';

// Days that carry suggested readings, in order.
const readingDays = days.filter((d) => (readings[d.n] ?? []).length > 0);

// Render an instructor name, linked to their profile when we have a slug.
function personHref(p?: Person): string | null {
  return p?.slug ? url(`instructors/${p.slug}`) : null;
}
---
<BaseLayout title="Curriculum">
  <Hero
    eyebrow="Curriculum & schedule"
    title="Seven days, one complete arc"
    lead="The week moves through the full lifecycle of an ML-for-health project — each day closing one gap from idea to bedside. Days pair a morning and an afternoon lecture with hands-on small-group and workshop time, and each content day builds a part of your private Project Workbook."
  />

  <section class="section">
    <div class="wrap">
      <div class="callout">
        <p>
          <strong>Accepted students:</strong> start with the
          <a href={url('before-you-arrive')}>Before you arrive</a> checklist —
          readings, your specialty track, accounts to set up, and what to bring.
        </p>
      </div>
      <div class="day-list">
        {days.map((d) => (
          <article class="day">
            <div class="day-num">{d.n}<span>Day</span></div>
            <div class="day-body">
              <p class="day-meta">{d.date} · <span class="day-mode">{d.mode}</span></p>
              <h3><a class="day-title-link" href={url(`curriculum/day-${d.n}`)}>{d.title}</a></h3>
              <p class="day-gap">{d.gap}</p>

              <p class="day-faculty">
                {d.lead && (
                  <span>
                    <strong>{d.leadLabel ?? 'AM lecture'}:</strong>{' '}
                    {personHref(d.lead)
                      ? <a href={personHref(d.lead)}>{d.lead.name}</a>
                      : <span>{d.lead.name}</span>}
                    {d.lead.affil && <span class="faculty-affil"> ({d.lead.affil})</span>}
                  </span>
                )}
                {d.guest && (
                  <span>
                    <strong>{d.guest2 ? 'PM lectures' : 'PM lecture'}:</strong>{' '}
                    {personHref(d.guest)
                      ? <a href={personHref(d.guest)}>{d.guest.name}</a>
                      : <span>{d.guest.name}</span>}
                    {d.guest.affil && <span class="faculty-affil"> ({d.guest.affil})</span>}
                    {d.guest2 && (
                      <>
                        {' & '}
                        {personHref(d.guest2)
                          ? <a href={personHref(d.guest2)}>{d.guest2.name}</a>
                          : <span>{d.guest2.name}</span>}
                        {d.guest2.affil && <span class="faculty-affil"> ({d.guest2.affil})</span>}
                      </>
                    )}
                  </span>
                )}
                {d.panel && <span><strong>Plus:</strong> a four-lens funding panel</span>}
              </p>

              <p><strong>Morning.</strong> {d.morning}</p>
              <p><strong>Afternoon.</strong> {d.afternoon}</p>
              <p class="day-questions"><strong>Key questions.</strong> {d.questions}</p>
              <p><a class="day-more" href={url(`curriculum/day-${d.n}`)}>Full day outline →</a></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">A typical day</p>
      <h2>The daily rhythm</h2>
      <p>
        Days 1–5 share one consistent five-block structure: morning lecture →
        small group → afternoon lecture → workshop → closing small group. The shape
        is deliberate — you get a frame, apply it to your project, get content
        that sharpens your thinking, then revise your work. <strong>Every content
        day ends with a small group</strong>, not a lecture, so the last thing
        you do each day is improve your own project and complete that day’s
        Project Workbook section. Day 1 uses the same structure with an 8:30
        opening block in place of the handoff; Day 6 is a funding panel with a
        free afternoon, and Day 7 is final presentations and networking.
      </p>
      <p>
        Those small groups are fixed <strong>home groups</strong> you stay in all
        week, with a peer facilitator who rotates daily. See
        <a href={url('small-groups')}>your group and the facilitator rotation</a>.
      </p>
      <dl class="rhythm">
        {dailyRhythm.map((b) => (
          <div class="rhythm-row"><dt>{b.time}</dt><dd>{b.item}</dd></div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section" id="suggested-readings">
    <div class="wrap">
      <p class="eyebrow">Suggested readings</p>
      <h2>Readings by day</h2>
      <p>
        Each content day has a short suggested-reading list. They’re also on each
        day’s page; the full set is collected here.
      </p>
      {readingDays.map((d) => (
        <div class="profile-block">
          <h3><a href={url(`curriculum/day-${d.n}`)}>Day {d.n} — {d.title}</a></h3>
          <ol class="reading-list">
            {(readings[d.n] ?? []).map((r) => (
              <li>{r.url ? <a href={r.url} rel="noopener" target="_blank">{r.cite}</a> : <span>{r.cite}</span>}</li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">How the days work</p>
      <h2>Concept in the morning, hands-on after</h2>
      <p>
        Each day pairs concept sessions with guided labs run as interactive
        notebooks. Days 3 and 4 close with a build-your-own-notebook workshop on
        your own project, with worked examples and templates provided.
      </p>
      <p>
        The deliverable from each day is added to your growing
        <strong>Project Workbook</strong> — so by the final day, the week’s work
        exists as a single, coherent reference you present and carry home.
      </p>
      <div class="callout">
        <p>
          <strong>Readings.</strong> Each content day has a short required
          reading list (around five papers); these will be posted here ahead of
          the camp.
        </p>
      </div>
      <div class="btn-row">
        <a class="btn btn-outline" href={url('instructors')}>Meet the instructors</a>
        <a class="btn btn-primary" href={url('resources')}>Camp resources</a>
      </div>
    </div>
  </section>
</BaseLayout>
