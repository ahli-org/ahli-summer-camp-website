---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE, url } from '../lib/site';

// Answers may contain HTML (links); rendered with set:html below.
const faqs = [
  {
    q: 'Who is the camp for?',
    a: 'The camp is designed for late-stage PhD students and early-career postdocs whose research involves machine learning for health. A working foundation in machine learning is expected. The 2026 cohort has been selected.',
  },
  {
    q: 'When and where does the camp take place?',
    a: `The camp runs ${SITE.dates} and is co-located with ${SITE.colocatedWith}. Venue details will be shared with accepted participants.`,
  },
  {
    q: 'How large is the cohort?',
    a: 'The 2026 cohort is 40 late-stage PhD students and early-career postdocs, kept intentionally small to allow real discussion and mentorship with instructors and peers.',
  },
  {
    q: 'What will I leave the camp with?',
    a: 'A sharper project and a private Project Workbook capturing your thinking across the week, plus a practice job talk and a poster from the final days — and a tight-knit cohort of peers. The Workbook is yours to keep, and it is not graded.',
  },
  {
    q: 'How should I prepare before the camp?',
    a: `Start with the <a href="${url('before-you-arrive')}">Before you arrive</a> checklist — suggested readings, choosing your specialty track, accounts to set up, and what to bring (a printed poster and a prospective project).`,
  },
  {
    q: 'Do I need to bring my own data?',
    a: 'No. Hands-on labs use synthetic clinical data modeled on MIMIC-IV structure, so everyone works from a common, realistic starting point.',
  },
  {
    q: 'Is there a cost, and is travel support available?',
    a: 'Details on fees and any available support are shared directly with accepted participants.',
  },
  {
    q: 'Is there a code of conduct?',
    a: `Yes. All participants, instructors, and organizers are expected to follow a code of conduct ensuring a respectful, harassment-free environment; the camp adopts the community standards of the co-located CHIL conference. Concerns can be raised confidentially with the organizers at ${SITE.email}.`,
  },
  {
    q: 'How do I request dietary, accessibility, or other accommodations?',
    a: `Email the organizers at ${SITE.email} with your needs as early as you can, and we'll make arrangements. Venue and catering details are shared with accepted participants.`,
  },
  {
    q: 'Will the sessions be recorded?',
    a: `Lecture recordings may be shared with the cohort after the camp. Participants are told in advance what will be recorded and can opt out of being captured; the same consent applies to the participant photos shown on the Students page. Questions about recording or media use go to ${SITE.email}.`,
  },
  {
    q: 'How can I stay informed?',
    a: `Accepted participants receive logistics by email. For anything else, reach the organizers at ${SITE.email}.`,
  },
];
---
<BaseLayout title="FAQ">
  <Hero
    eyebrow="Frequently asked questions"
    title="Good to know about the camp"
    lead="Answers to the most common questions about the camp. If something is not covered here, get in touch."
  />

  <section class="section">
    <div class="wrap">
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p set:html={f.a} />
          </div>
        ))}
      </div>

      <div class="callout">
        <p>
          Still have a question? Email
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a> and the organizers
          will be glad to help.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
