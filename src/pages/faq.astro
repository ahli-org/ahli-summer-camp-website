---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE } from '../lib/site';

const faqs = [
  {
    q: 'Who is the camp for?',
    a: 'The camp is designed for PhD students whose research involves machine learning for health. A working foundation in machine learning is expected. The 2026 cohort has been selected.',
  },
  {
    q: 'When and where does the camp take place?',
    a: `The camp runs ${SITE.dates} and is co-located with ${SITE.colocatedWith}. Venue details will be shared with accepted participants.`,
  },
  {
    q: 'How large is the cohort?',
    a: 'The 2026 cohort is 45 PhD students and early-career researchers, kept intentionally small to allow real discussion and mentorship with instructors and peers.',
  },
  {
    q: 'What will I leave the camp with?',
    a: 'Each day produces a concrete deliverable. Together these form a cohesive Project Workbook — a structured reference you can carry back into your own research.',
  },
  {
    q: 'Do I need to bring my own data?',
    a: 'No. Hands-on labs use synthetic clinical data modeled on MIMIC-IV structure, so everyone works from a common, realistic starting point.',
  },
  {
    q: 'Is there a cost, and is travel support available?',
    a: 'Details on fees and any available support are shared directly with accepted participants.',
  },
  {
    q: 'How can I stay informed?',
    a: `Accepted participants receive logistics by email. For anything else, reach the organizers at ${SITE.email}.`,
  },
];
---
<BaseLayout title="FAQ">
  <Hero
    eyebrow="Frequently asked questions"
    title="Good to know about the camp"
    lead="Answers to the most common questions about the camp. If something is not covered here, get in touch."
  />

  <section class="section">
    <div class="wrap">
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>

      <div class="callout">
        <p>
          Still have a question? Email
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a> and the organizers
          will be glad to help.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
