---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, url } from '../lib/site';

const facts = [
  { k: 'Dates', v: SITE.dates },
  { k: 'Format', v: 'Week-long, in-person intensive' },
  { k: 'Cohort', v: '40 researchers in ML for health' },
  { k: 'Venue', v: 'Alder Commons (Mon–Thu, Sat–Sun) · Maple Hall Great Room (Fri)' },
  { k: 'Supported by', v: SITE.funder },
  { k: 'Outcome', v: 'A sharper project, a practice job talk & a poster' },
];
---
<BaseLayout title="Home">
  <header class="hero hero--home">
    <div class="hero-inner">
      <span class="date-badge">{SITE.dates}</span>
      <h1>AHLI Health AI<br />Summer Camp {SITE.year}</h1>
      <p class="hero-lead">
        A rigorous, hands-on week for late-stage PhD students and early-career
        postdocs building machine learning for health — from clinical data to
        evaluation, modeling, and real-world translation.
      </p>
      <div class="btn-row">
        <a class="btn btn-primary" href={url('curriculum')}>See the curriculum</a>
        <a class="btn btn-ghost" href={url('students')}>Meet the cohort</a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">About the camp</p>
      <h2>One intensive week, built around doing the work</h2>
      <p class="lead">
        The AHLI Health AI Summer Camp brings together late-stage PhD students and
        early-career postdocs working at the intersection of machine learning and
        health. Over a single
        focused week, participants move through the full arc of an ML-for-health
        project alongside leading instructors and a tight-knit cohort of peers.
      </p>
      <p>
        Rather than a lecture series, the camp is built around your own project.
        Each day pairs a concept session with hands-on small-group work, and your
        thinking accumulates in a personal <strong>Project Workbook</strong> you
        carry home — closing, on the final days, with a practice job talk and a
        poster.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">At a glance</p>
      <h2>The essentials</h2>
      <dl class="facts">
        {facts.map((f) => (
          <div class="fact"><dt>{f.k}</dt><dd>{f.v}</dd></div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cta">
        <h2>The {SITE.year} cohort is set</h2>
        <p>Meet the students and instructors joining us for the week, and explore the curriculum.</p>
        <div class="btn-row">
          <a class="btn btn-primary" href={url('students')}>Meet the cohort</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
