---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PersonCard from '../components/PersonCard.astro';
import { url } from '../lib/site';
import { instructors } from '../lib/people';

// Edit the instructor list in src/lib/people.ts (the `instructors` array).
const announced = instructors.some((p) => p.name !== 'Instructor to be announced');
---
<BaseLayout title="Instructors">
  <Hero
    eyebrow="Instructors"
    title="Learn from researchers shaping health AI"
    lead="The camp is led by instructors working at the frontier of machine learning for health, supported by a program committee that runs the week."
  />

  <section class="section">
    <div class="wrap">
      {!announced && (
        <div class="callout">
          <p>
            <strong>The faculty lineup is being finalized.</strong> Confirmed
            instructors and full bios will be published here ahead of the camp.
          </p>
        </div>
      )}

      <div class="people-grid">
        {instructors.map((p) => <PersonCard person={p} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Behind the camp</p>
      <h2>Program committee</h2>
      <p>
        The camp is organized by a program committee responsible for the
        curriculum, logistics, and participant experience throughout the week.
        Committee members and their roles will be listed here soon.
      </p>
      <div class="btn-row">
        <a class="btn btn-outline" href={url('curriculum')}>See the curriculum</a>
        <a class="btn btn-primary" href={url('students')}>Meet the cohort</a>
      </div>
    </div>
  </section>
</BaseLayout>
