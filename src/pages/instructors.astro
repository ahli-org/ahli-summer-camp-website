---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProfileCard from '../components/ProfileCard.astro';
import { url } from '../lib/site';
import { instructors } from '../lib/instructors';

// All lecturers in one list — they share the same lecture slot, so we don't split
// them into a hierarchy. Order is the stable shuffle from the data.
const groups = [
  { heading: 'Lecturers', blurb: 'The faculty leading the week’s lectures and sessions.', people: instructors },
];
---
<BaseLayout title="Instructors">
  <Hero
    eyebrow="Instructors"
    title="Learn from researchers shaping health AI"
    lead={`The camp is led by ${instructors.length} instructors working at the frontier of machine learning for health. Explore their work below.`}
  />

  {groups.map((g) => g.people.length > 0 && (
    <section class="section">
      <div class="wrap wrap--wide">
        <h2>{g.heading}</h2>
        <p class="section-lead">{g.blurb}</p>
        <div class="people-grid people-grid--profiles">
          {g.people.map((p) => (
            <ProfileCard
              href={url(`instructors/${p.slug}`)}
              name={p.name}
              photo={p.photo}
              tagline={p.tagline}
              affiliation={p.affiliation}
              links={p.links}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Behind the camp</p>
      <h2>Program committee</h2>
      <p>
        The camp is organized by a program committee responsible for the
        curriculum, logistics, and participant experience throughout the week.
      </p>
      <div class="btn-row">
        <a class="btn btn-outline" href={url('instructor-guide')}>Instructor guide</a>
        <a class="btn btn-outline" href={url('curriculum')}>See the curriculum</a>
        <a class="btn btn-primary" href={url('students')}>Meet the cohort</a>
      </div>
    </div>
  </section>
</BaseLayout>
