---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProfileCard from '../components/ProfileCard.astro';
import { url } from '../lib/site';
import { instructors } from '../lib/instructors';
---
<BaseLayout title="Instructors">
  <Hero
    eyebrow="Instructors"
    title="Learn from researchers shaping health AI"
    lead={`The camp is led by ${instructors.length} instructors and guest lecturers working at the frontier of machine learning for health. Explore their work below.`}
  />

  <section class="section">
    <div class="wrap">
      <div class="people-grid people-grid--profiles">
        {instructors.map((p) => (
          <ProfileCard
            href={url(`instructors/${p.slug}`)}
            name={p.name}
            photo={p.photo}
            subtitle={p.role}
            affiliation={p.affiliation}
            links={p.links}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Behind the camp</p>
      <h2>Program committee</h2>
      <p>
        The camp is organized by a program committee responsible for the
        curriculum, logistics, and participant experience throughout the week.
        Committee members and their roles will be listed here soon.
      </p>
      <div class="btn-row">
        <a class="btn btn-outline" href={url('curriculum')}>See the curriculum</a>
        <a class="btn btn-primary" href={url('students')}>Meet the cohort</a>
      </div>
    </div>
  </section>
</BaseLayout>
