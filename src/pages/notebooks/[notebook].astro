---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { marked } from 'marked';
import { Code } from 'astro:components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/site';
import { notebooks, colabUrl } from '../../lib/notebooks';
import type { NotebookMeta } from '../../lib/notebooks';

interface Cell { type: 'markdown' | 'code'; source: string }

export function getStaticPaths() {
  return notebooks.map((meta) => {
    const path = fileURLToPath(new URL(`../../../public/notebooks/${meta.file}`, import.meta.url));
    const nb = JSON.parse(readFileSync(path, 'utf8'));
    const cells: Cell[] = (nb.cells ?? [])
      .filter((c: any) => c.cell_type === 'markdown' || c.cell_type === 'code')
      .map((c: any) => ({
        type: c.cell_type,
        // Drop the Colab badge line (the page provides its own buttons; the
        // badge stays in the .ipynb for GitHub/standalone viewing).
        source: (Array.isArray(c.source) ? c.source.join('') : (c.source ?? ''))
          .split('\n').filter((l: string) => !l.includes('colab-badge')).join('\n'),
      }))
      .filter((c: Cell) => c.source.trim().length > 0);
    return { params: { notebook: meta.slug }, props: { meta, cells } };
  });
}

interface Props { meta: NotebookMeta; cells: Cell[] }
const { meta, cells } = Astro.props;
const base = import.meta.env.BASE_URL;
const downloadHref = `${base}notebooks/${meta.file}`;
---
<BaseLayout title={`${meta.title} (notebook)`} description={meta.blurb}>
  <header class="hero hero--profile">
    <div class="hero-inner">
      <a class="profile-back" href={url(`curriculum/day-${meta.day}`)}>← Day {meta.day} curriculum</a>
      <p class="hero-eyebrow">Workshop notebook · Day {meta.day}</p>
      <h1>{meta.title}</h1>
      <p class="hero-lead">{meta.blurb}</p>
      <div class="nb-actions">
        <a class="btn btn-primary btn-icon" href={colabUrl(meta.file)} rel="noopener" target="_blank">
          <Icon name="colab" size={18} /> Open in Colab
        </a>
        <a class="btn btn-ghost btn-icon" href={downloadHref} download>
          <Icon name="download" size={18} /> Download .ipynb
        </a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="wrap wrap--xwide">
      <div class="callout">
        <p>
          This is a <strong>template</strong> to adapt to your own project — work
          through the sections below. To run it: open in Colab (one click, no
          install), or download it and run locally with
          <code>pip install -r requirements.txt</code> (the
          <a href={`${base}notebooks/requirements.txt`}>requirements file</a> is
          alongside the notebooks). The notebook includes a binary substrate and
          a time-to-event alternative; imaging/text/genomics projects feed their
          encoder output in as the feature matrix.
        </p>
        <p style="margin-top:.6rem">
          <strong>Note:</strong> “Open in Colab” loads the notebook from GitHub,
          so it requires repository access until the site is public — if it
          doesn’t open, use <em>Download .ipynb</em> and upload it to Colab, or
          run it locally.
        </p>
      </div>

      <div class="notebook">
        {cells.map((cell) => (
          cell.type === 'markdown'
            ? <div class="nb-md" set:html={marked.parse(cell.source)} />
            : <div class="nb-code"><Code code={cell.source} lang="python" theme="github-light" /></div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
