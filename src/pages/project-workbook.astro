---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { url } from '../lib/site';
import { Content } from '../md/project-workbook.md';
---
<BaseLayout title="Project Workbook" description="The five-part Project Workbook — a private thinking aid each participant keeps for their own project, one part per content day. Not turned in, not graded.">
  <Hero
    eyebrow="Your thinking aid"
    title="The Project Workbook"
    lead="A private notebook for your own project — five short parts, one per content day. It's yours: not turned in, not graded. The point is clearer thinking, not a finished document."
  />
  <section class="section">
    <div class="wrap">
      <div class="callout">
        <p>
          New to the format? See a <a href={url('project-workbook/example')}>fully
          worked example</a> — a completed Workbook for a fictional project — to
          calibrate what a strong entry looks like.
        </p>
      </div>
      <div class="day-detail">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
