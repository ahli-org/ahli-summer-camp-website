---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE, url } from '../lib/site';
import { studentResources, instructorResources } from '../lib/resources';
import type { Resource } from '../lib/resources';

const sections: { heading: string; eyebrow: string; items: Resource[] }[] = [
  { eyebrow: 'For students', heading: 'Student resources', items: studentResources },
  { eyebrow: 'For instructors', heading: 'Instructor resources', items: instructorResources },
];

const linkFor = (r: Resource) => (r.internal ? url(r.internal) : (r.href ?? '#'));
const isInternal = (r: Resource) => Boolean(r.internal);
---
<BaseLayout title="Resources">
  <Hero
    eyebrow="Resources"
    title="Materials for the camp"
    lead="Reading, setup guides, lab notebooks, slides, and session recordings — gathered here as they’re ready. Everything is open."
  />

  {sections.map((s) => (
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">{s.eyebrow}</p>
        <h2>{s.heading}</h2>
        <ul class="resource-list">
          {s.items.map((r) => (
            <li class="resource">
              <div class="resource-main">
                <a href={linkFor(r)} {...(isInternal(r) ? {} : { rel: 'noopener', target: '_blank' })}>{r.title}</a>
                {r.description && <p>{r.description}</p>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="section">
    <div class="wrap">
      <div class="callout">
        <p>
          Materials are posted here as they’re finalized. Questions about the
          resources? Email <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
